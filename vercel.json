{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.svg|favicon-32x32\\.png|favicon-16x16\\.png|apple-touch-icon\\.png|robots\\.txt|rss\\.xml|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}

{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.notasdeberlim.com" }],
      "destination": "https://notasdeberlim.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/edicoes/:slug", "destination": "/api/edicao-og?slug=:slug" }
  ]
}
